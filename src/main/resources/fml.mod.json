{
  "schemaVersion": 1,
  "id": "kawakaze",
  "name": "Kawakaze Lib",
  "version": "${version}",
  "description": "A lib mod",
  "icon": "assets/kawakazelib/icon.png",
  "authors": [
    "yuchenxue"
  ],
  "depends": {
    "fishmodloader": ">=3.4.1",
    "fish-language-kotlin": ">=1.1.4.2310"
  },
  "environment": "*",
  "entrypoints": {
    "main": [
      {
        "adapter": "kotlin",
        "value": "cute.neko.kawakaze.KawakazeLib"
      }
    ]
  },
  "mixins": [
    "kawakaze.mixins.json"
  ],
  "accessWidener": "kawakaze.accesswidener"
}